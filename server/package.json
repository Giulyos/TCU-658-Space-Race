{
  "name": "space-race-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "build:pkg": "pkg . --targets node22-linux-x64,node22-macos-x64,node22-win-x64 --output ../dist/space-race",
    "build:pkg:host": "pkg . --targets node22 --output ../dist/space-race"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@yao-pkg/pkg": "^6.6.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "app.js",
      "openBrowser.js",
      "routes/**/*.js",
      "db/**/*.js",
      "middleware/**/*.js",
      "game/**/*.js",
      "!**/*.test.js",
      "!db/persistence-demo.mjs",
      "!game/cli.js"
    ],
    "assets": [
      "../client/dist/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "game/*.json"
    ]
  }
}
